# AWS Configuration
# Copy file ini ke .env dan isi dengan nilai yang sebenarnya
# JANGAN commit file .env ke GitHub!

# AWS region yang ingin dianalisis
AWS_REGION=ap-southeast-1

# Opsional: gunakan AWS profile tertentu (dari ~/.aws/credentials)
# Kosongkan jika pakai default profile
AWS_PROFILE=default

# Budget threshold dalam USD — alert jika cost melebihi nilai ini
COST_THRESHOLD_USD=100.0

# Periode default (dalam bulan ke belakang)
LOOKBACK_MONTHS=3
